# =============================================================================
# Vision Computer Project - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste conforme necessário
# cp .env.example .env

# =============================================================================
#Geral
# =============================================================================

# Ambiente: development, staging, production
ENVIRONMENT=development

# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Diretório para dados temporários e cache
DATA_DIR=./data

# =============================================================================
# Ética e Segurança
# =============================================================================

# Modo estrito para auditoria ética (bloqueia análises de alto risco)
ETHICS_STRICT_MODE=true

# Dias de retenção de dados biométricos (0 = sem armazenamento)
DATA_RETENTION_DAYS=7

# Exigir consentimento explícito para análise
REQUIRE_CONSENT=true

# Habilitar logs de auditoria ética
ETHICS_LOGGING=true

# =============================================================================
#API
# =============================================================================

# Host da API
API_HOST=0.0.0.0

# Porta da API
API_PORT=8000

# Endpoint base da API
API_PREFIX=/api/v1

# CORS origins permitidos (separado por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# =============================================================================
# Streamlit
# =============================================================================

# Porta do Streamlit
STREAMLIT_PORT=8501

# Habilitar modo headless para Streamlit
STREAMLIT_HEADLESS=true

# =============================================================================
#Modelos de IA
# =============================================================================

# Tipo de modelo GAN: fallback, stylegan2, pix2pix, cyclegan
GAN_MODEL_TYPE=fallback

# Caminho para modelo GAN pré-treinado (opcional)
GAN_MODEL_PATH=""

# Dispositivo para inferência: cuda, cpu, mps (Mac)
INFERENCE_DEVICE=auto

# Resolução das imagens para GAN (128, 256, 512)
GAN_RESOLUTION=256

# =============================================================================
#GPU e Performance
# =============================================================================

# Habilitar aceleração GPU
ENABLE_GPU=false

# Limite de memória GPU (MB, 0 = ilimitado)
GPU_MEMORY_LIMIT=0

# Batch size para processamento
BATCH_SIZE=1

# Número de workers para processamento paralelo
NUM_WORKERS=2

# =============================================================================
# Banco de Dados (opcional)
# =============================================================================

# URL de conexão com banco de dados
# SQLite (padrão): sqlite:///./data/vision_aesthetics.db
# PostgreSQL: postgresql://user:password@localhost:5432/vision_db
DATABASE_URL=sqlite:///./data/vision_aesthetics.db

# Pool size para conexões
DB_POOL_SIZE=5

# =============================================================================
# Autenticação (opcional)
# =============================================================================

# Habilitar autenticação
AUTH_ENABLED=false

# Segredo para JWT (gerar com: python -c "import secrets; print(secrets.token_urlsafe())")
JWT_SECRET=change-me-in-production

# Tempo de expiração do token em minutos
TOKEN_EXPIRE_MINUTES=30

# =============================================================================
#API Externa (opcional)
# =============================================================================

# Chave de API para Hugging Face (para modelos GAN remotos)
HUGGINGFACE_API_KEY=""

# Endpoint para modelos externos
MODEL_ENDPOINT=""

# =============================================================================
# Monitoramento e Telemetria (opcional)
# =============================================================================

# Habilitar métricas Prometheus
METRICS_ENABLED=false

# Endpoint para envio de traces (OpenTelemetry)
OTEL_EXPORTER_ENDPOINT=""

# =============================================================================
#Limites e Quotas
# =============================================================================

# Tamanho máximo de imagem (MB)
MAX_IMAGE_SIZE_MB=10

# Requisições por minuto por IP (rate limiting)
RATE_LIMIT_PER_MINUTE=60

# Requisições por dia por usuário
DAILY_QUOTA=1000

# =============================================================================
# Backup e Recuperação
# =============================================================================

# Habilitar backup automático
BACKUP_ENABLED=false

# Frequência do backup (cron expression)
BACKUP_SCHEDULE=0 2 * * *

# Diretório de backup
BACKUP_DIR=./backups