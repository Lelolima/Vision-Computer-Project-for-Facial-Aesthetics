# Docker ignore para Vision Computer Project

# =============================================================================
# Git
# =============================================================================
.git
.gitignore
.gitmodules
.gitattributes

# =============================================================================
# Ambiente e Segredos (NUNCA incluir no build)
# =============================================================================
.env
.env.*
*.env
!*.env.example
secrets.json
credentials.json
*.pem
*.key

# =============================================================================
# Dados Sensíveis
# =============================================================================
data/
!data/.gitkeep
logs/
!logs/.gitkeep
ethics_logs/
!ethics_logs/.gitkeep

# Imagens de usuários
*.jpg
*.jpeg
*.png
*.gif
!docs/assets/*.png

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv
*.egg-info/
.installed.cfg
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.dmypy.json

# Linting
.ruff_cache/

# =============================================================================
# IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# Modelos (usar download separado ou volume)
# =============================================================================
models/*.pt
models/*.pth
models/*.h5
models/*.onnx
models/*.ckpt
!models/.gitkeep

# Cache de ML
.huggingface/
.torch/
cache/

# =============================================================================
# Build e Artefatos
# =============================================================================
build/
dist/
*.egg-info/
*.egg

# Docker
docker-compose.override.yml
.docker/

# =============================================================================
# Documentação Gerada
# =============================================================================
docs/_build/
site/
pdoc/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints
*.ipynb_checkpoints

# =============================================================================
# Específicos
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
*.log
*.tmp
*.temp